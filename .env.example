# ─────────────────────────────────────────────────────────────────
# Meridian Data — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────

# ── Groq API Key Pool (round-robin rotation) ─────────────────────
# Add up to 6 Groq API keys. When one key hits its rate limit,
# Meridian automatically rotates to the next key.
# Rotation order: KEY_1 → KEY_2 → KEY_3 → KEY_4 → KEY_5 → KEY_6 → KEY_1 → ...
#
# • You only need KEY_1 to get started.
# • Add more keys to increase throughput and avoid interruptions.
# • Get keys at: https://console.groq.com
#
GROQ_API_KEY_1=your_groq_api_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=

# ── Flask Security ────────────────────────────────────────────────
# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_a_generated_64_char_hex_string

# ── Flask Runtime ─────────────────────────────────────────────────
# Set to true ONLY for local development — never in production.
FLASK_DEBUG=false
