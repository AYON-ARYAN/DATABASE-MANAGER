flowchart TB
  USER(["User"])
  LLMP(["LLM Provider"])
  DBEXT[("Target Database")]

  P1["1.0<br/>Authenticate<br/>and Authorize"]
  P2["2.0<br/>Route Intent /<br/>Match Command"]
  P3["3.0<br/>Generate SQL<br/>(schema-aware)"]
  P4["4.0<br/>Classify and<br/>Validate (safety)"]
  P5["5.0<br/>Execute or<br/>Review Write"]
  P6["6.0<br/>Analyze and<br/>Visualize"]

  D1[("Connections /<br/>Credentials")]
  D2[("Conversation<br/>Context / History")]
  D3[("Snapshots")]
  D4[("Usage Metrics")]

  USER -- "credentials" --> P1
  P1 -- "session, role" --> P2
  P1 <-- "stored creds" --> D1
  USER -- "NL command" --> P2
  P2 -- "introspection request" --> P5
  P2 -- "NL + schema" --> P3
  P3 <-- "prompt / SQL" --> LLMP
  P3 -- "history turns" --> D2
  P3 -- "candidate SQL" --> P4
  P4 -- "task + safe SQL" --> P5
  P4 -- "latency / tokens" --> D4
  P5 -- "query" --> DBEXT
  DBEXT -- "rows / schema" --> P5
  P5 -- "auto-backup" --> D3
  P5 -- "result set" --> P6
  P6 -- "results, charts, insights" --> USER
  P6 -- "data sample" --> LLMP
